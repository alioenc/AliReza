{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "simple-data-api",
  "description": "Public API for data processing and status reporting",
  
  "functions": {
    "api/index.js": {
      "maxDuration": 20,
      "memory": 1024
    }
  },

  "routes": [
    {
      "src": "/healthz",
      "dest": "/api/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/process",
      "dest": "/api/index.js",
      "methods": ["POST"]
    },
    {
      "src": "/status",
      "dest": "/api/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/v1/(.*)",
      "dest": "/api/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE"]
    }
  ],

  "trailingSlash": false,
  "cleanUrls": true,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
